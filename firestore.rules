rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /apostas/{apostaId} {

      // Qualquer pessoa pode ver a lista de palpites
      allow read: if true;

      // Qualquer pessoa pode CRIAR seu palpite, desde que:
      // - pago comece false, valorPago comece 0, resultado comece vazio
      // - nome e placares tenham o tipo certo
      allow create: if request.resource.data.pago == false
                    && request.resource.data.valorPago == 0
                    && request.resource.data.resultado == ""
                    && request.resource.data.nome is string
                    && request.resource.data.golsBrasil is int
                    && request.resource.data.golsNoruega is int;

      // Atualização é permitida se:
      // - quem está alterando é o admin (pode mudar QUALQUER campo, inclusive
      //   placar, pago, valorPago e resultado), OU
      // - a pessoa está só reenviando/corrigindo o próprio palpite (nome e
      //   placar) e NÃO mexeu em pago, valorPago nem resultado
      allow update: if isAdmin() || naoAlterouCamposDoAdmin();

      function isAdmin() {
        return request.auth != null
               && request.auth.token.email == "mmunizjunior@gmail.com";
      }

      function naoAlterouCamposDoAdmin() {
        return request.resource.data.pago == resource.data.pago
               && request.resource.data.valorPago == resource.data.valorPago
               && request.resource.data.resultado == resource.data.resultado;
      }
    }
  }
}
